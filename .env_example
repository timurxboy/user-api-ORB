# Poetry (optional extras)
POETRY_EXTRAS="s3"

# App
ENV=local
APP_PORT=8000

# Postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=users_api
DB_PATH=/mnt/data/users-api-psql

# Security
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Verification / cleanup
VERIFICATION_CODE_EXPIRE_MINUTES=30
UNVERIFIED_RETENTION_DAYS=2

# Email (console = print code to log; smtp = send via provider)
EMAIL_BACKEND=console
# Example: Brevo (free 300 emails/day) — https://www.brevo.com
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@example.com
SMTP_USE_TLS=true

# Logging
LOG_DIR="logs"
LOG_FILE="app.log"
LOG_LEVEL="INFO"
